<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const drawerPanel = document.getElementById('drawer-panel');
  const drawerBackdrop = document.getElementById('drawer-backdrop');
  const closeDrawer = document.getElementById('close-drawer');
  
  function openDrawer() {
    mobileDrawer?.classList.remove('hidden');
    setTimeout(() => {
      drawerPanel?.classList.remove('translate-x-full');
    }, 10);
    document.body.style.overflow = 'hidden';
  }
  
  function closeDrawerHandler() {
    drawerPanel?.classList.add('translate-x-full');
    setTimeout(() => {
      mobileDrawer?.classList.add('hidden');
    }, 300);
    document.body.style.overflow = '';
  }
  
  menuBtn?.addEventListener('click', openDrawer);
  closeDrawer?.addEventListener('click', closeDrawerHandler);
  drawerBackdrop?.addEventListener('click', closeDrawerHandler);
</script>

<script is:inline>
(function() {
  var searchInput = document.getElementById('search-input');
  var searchResults = document.getElementById('search-results');
  var mobileSearchInput = document.getElementById('mobile-search-input');
  var mobileSearchResults = document.getElementById('mobile-search-results');
  var searchData = null;
  var debounceTimer = null;

  function loadSearchData() {
    if (searchData) return Promise.resolve(searchData);
    return fetch('/search.json')
      .then(function(r) { return r.json(); })
      .then(function(data) { searchData = data; return data; })
      .catch(function() { return []; });
  }

  function highlightText(text, query) {
    if (!query) return text;
    var regex = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.replace(regex, '<mark class="bg-yellow-200 rounded px-0.5">$1</mark>');
  }

  function renderResults(results, query, container) {
    if (results.length === 0) {
      container.innerHTML = '<div class="p-4 text-center text-gray-500 text-sm">未找到相关文章</div>';
    } else {
      container.innerHTML = results.map(function(post) {
        var tagsHtml = post.tags && post.tags.length > 0
          ? post.tags.slice(0, 3).map(function(t) { return '<span class="inline-block px-1.5 py-0.5 bg-gray-100 text-gray-500 text-xs rounded mr-1">#' + t + '</span>'; }).join('')
          : '';
        return '<a href="/posts/' + post.slug + '" class="block px-4 py-3 hover:bg-indigo-50 transition-colors border-b border-gray-50 last:border-0">' +
          '<div class="font-medium text-gray-900 text-sm mb-1">' + highlightText(post.title, query) + '</div>' +
          (post.excerpt ? '<div class="text-gray-500 text-xs line-clamp-1 mb-1">' + highlightText(post.excerpt.substring(0, 80), query) + '</div>' : '') +
          '<div class="flex items-center gap-2">' +
            (post.categoryName ? '<span class="text-xs text-indigo-600">' + post.categoryName + '</span>' : '') +
            '<span class="text-xs text-gray-400">' + post.date + '</span>' +
            tagsHtml +
          '</div>' +
        '</a>';
      }).join('');
    }
    container.classList.remove('hidden');
  }

  function doSearch(query, resultsContainer) {
    if (!query || query.length < 1) {
      resultsContainer.classList.add('hidden');
      return;
    }
    loadSearchData().then(function(data) {
      var q = query.toLowerCase();
      var results = data.filter(function(post) {
        return post.title.toLowerCase().includes(q) ||
               (post.excerpt && post.excerpt.toLowerCase().includes(q)) ||
               (post.categoryName && post.categoryName.toLowerCase().includes(q)) ||
               (post.tags && post.tags.some(function(t) { return t.toLowerCase().includes(q); }));
      }).slice(0, 8);
      renderResults(results, query, resultsContainer);
    });
  }

  function setupSearch(input, resultsContainer, containerId) {
    if (!input) return;
    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      var val = this.value.trim();
      debounceTimer = setTimeout(function() { doSearch(val, resultsContainer); }, 200);
    });
    input.addEventListener('focus', function() {
      if (this.value.trim()) doSearch(this.value.trim(), resultsContainer);
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        resultsContainer.classList.add('hidden');
        input.blur();
      }
    });
  }

  setupSearch(searchInput, searchResults, 'search-container');
  setupSearch(mobileSearchInput, mobileSearchResults, 'mobile-search-container');

  document.addEventListener('click', function(e) {
    var container = document.getElementById('search-container');
    if (container && !container.contains(e.target)) searchResults.classList.add('hidden');
    var mContainer = document.getElementById('mobile-search-container');
    if (mContainer && !mContainer.contains(e.target)) mobileSearchResults.classList.add('hidden');
  });
})();
</script>