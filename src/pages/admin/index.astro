---
import '../../styles/global.css';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录 - XiaoHe 博客管理后台</title>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <div class="text-center mb-8">
        <img src="https://tu.hexiaoyiok.dpdns.org/1776234509553_9e0u4c_avatar.png" alt="头像" class="w-20 h-20 rounded-full mx-auto mb-4 ring-4 ring-blue-50" />
        <h1 class="text-2xl font-bold text-gray-900">XiaoHe 博客</h1>
        <p class="text-gray-500 text-sm mt-1">管理后台登录</p>
      </div>

      <form id="login-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">用户名</label>
          <input type="text" id="username" required placeholder="请输入用户名"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">密码</label>
          <input type="password" id="password" required placeholder="请输入密码"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
        </div>
        <button type="submit"
          class="w-full py-2.5 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 active:bg-blue-800 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
          登 录
        </button>
      </form>

      <div id="error-message" class="hidden mt-4 p-3 bg-red-50 text-red-600 rounded-xl text-sm text-center"></div>
      <p class="text-center text-xs text-gray-400 mt-6">默认账号: admin / admin123</p>
    </div>

    <div class="text-center mt-4">
      <a href="/" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">← 返回首页</a>
    </div>
  </div>

  <script is:inline>
    if (localStorage.getItem('admin_logged_in') === 'true') {
      window.location.href = '/admin/dashboard';
    }

    document.getElementById('login-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var username = document.getElementById('username').value;
      var password = document.getElementById('password').value;
      var errorDiv = document.getElementById('error-message');

      var storedUser = localStorage.getItem('admin_username') || 'admin';
      var storedPass = localStorage.getItem('admin_password') || 'admin123';

      if (username === storedUser && password === storedPass) {
        localStorage.setItem('admin_logged_in', 'true');
        localStorage.setItem('admin_login_time', new Date().toISOString());
        window.location.href = '/admin/dashboard';
      } else {
        errorDiv.textContent = '用户名或密码错误';
        errorDiv.classList.remove('hidden');
        setTimeout(function() { errorDiv.classList.add('hidden'); }, 3000);
      }
    });
  </script>
</body>
</html>
