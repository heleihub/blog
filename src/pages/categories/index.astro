---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategories } from '../../lib/content';

const categories = await getCategories();
---

<BaseLayout title="所有分类" description="浏览所有文章分类">
  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h1 class="text-3xl font-bold mb-2">分类</h1>
      <p class="text-gray-600">浏览所有文章分类</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((category: any) => (
        <a 
          href={`/categories/${category.slug}`}
          class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition-all hover:-translate-y-1"
        >
          <h3 class="text-xl font-semibold mb-2">{category.name}</h3>
          {category.description && (
            <p class="text-gray-600 text-sm">{category.description}</p>
          )}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
