---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCategories } from '../../lib/content';
import { getViews } from '../../lib/config';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const viewsData = await getViews();
const postViews = viewsData[post.slug] || 0;

// 获取分类中文名
const categoryDefinitions = await getCategories();
const categoryNameMap = new Map<string, string>();
categoryDefinitions.forEach((cat: any) => {
  categoryNameMap.set(cat.slug || cat.id, cat.name);
});
const categoryDisplayName = categoryNameMap.get(post.data.category) || post.data.category;
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Main Content -->
    <article class="flex-1 min-w-0">
      <div class="bg-white rounded-xl shadow-sm p-8">
        <!-- Post Header -->
        <header class="mb-8 pb-8 border-b border-gray-200">
          <h1 class="text-4xl font-bold text-gray-900 mb-4">{post.data.title}</h1>
          
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
              </svg>
              {post.data.author}
            </div>
            
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
              </svg>
              <time datetime={post.data.date}>{post.data.date}</time>
            </div>

            <div class="flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <span id="post-views" data-slug={post.slug} data-baseline={String(postViews)}>{postViews}</span> 阅读
            </div>
            
            {post.data.category && (
              <a 
                href={`/categories/${post.data.category}`}
                class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full hover:bg-indigo-200 transition-colors"
              >
                {categoryDisplayName}
              </a>
            )}
          </div>
          
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag: string) => (
              <a 
                href={`/tags/${tag}`}
                class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm hover:bg-gray-200 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </header>
        
        <!-- Post Content -->
        <div class="prose prose-lg max-w-none" id="post-body">
          <Content />
        </div>
        <div id="hidden-content-wrapper"></div>

        <!-- Share Buttons -->
        <div class="mt-8 pt-6 border-t border-gray-200">
          <h4 class="text-sm font-semibold text-gray-700 mb-3">分享到</h4>
          <div class="flex flex-wrap gap-2">
            <!-- X (Twitter) -->
            <button onclick="shareToX()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors text-sm" title="分享到 X">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X
            </button>
            <!-- Facebook -->
            <button onclick="shareToFacebook()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm" title="分享到 Facebook">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </button>
            <!-- 微信 -->
            <button onclick="shareToWeChat()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors text-sm" title="分享到微信">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.492.492 0 01.177-.554C23.016 18.514 24 16.89 24 15.074c0-3.191-2.73-5.927-7.062-6.216zM14.033 13.3c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/></svg>
              微信
            </button>
            <!-- 新浪微博 -->
            <button onclick="shareToWeibo()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm" title="分享到新浪微博">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zm-1.119-6.724c-2.385.334-3.949 2.081-3.492 3.902.453 1.818 2.736 2.972 5.12 2.644 2.381-.334 3.945-2.08 3.492-3.9-.457-1.822-2.736-2.975-5.12-2.646zm1.581 3.273c-.378.527-1.224.781-1.884.564-.656-.213-.878-.807-.5-1.334.374-.525 1.215-.778 1.872-.566.659.218.886.812.512 1.336zm1.29-.832c-.145.199-.462.293-.711.213-.247-.082-.334-.307-.19-.506.145-.199.46-.293.71-.213.248.082.336.307.191.506zm-3.641-6.832c-4.071-.957-8.647.992-9.197 4.09-.553 3.098 3.045 6.279 7.916 6.832 5.119.582 9.279-1.955 9.279-5.164 0-3.068-3.447-5.729-7.998-5.758zM20.5 5.709c-.732-1.898-2.766-2.94-4.537-2.328l-.098.035c-.271.105-.408.416-.301.693.105.277.412.418.686.311l.105-.037c1.143-.426 2.545.246 3.119 1.498.574 1.252.096 2.656-1.066 3.131l-.1.039c-.271.107-.408.418-.301.695.105.275.412.416.686.311l.098-.039c1.771-.682 2.646-2.711 1.914-4.609h-.004z"/></svg>
              微博
            </button>
            <!-- 复制链接 -->
            <button onclick="copyLink()" id="copy-btn" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors text-sm" title="复制链接">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
              复制链接
            </button>
          </div>
        </div>
      </div>
      
      <!-- Comments Section -->
      <div class="bg-white rounded-xl shadow-sm p-6 mt-6">
        <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          评论
        </h3>
        
        <!-- Comment Form -->
        <div class="mb-8 p-4 bg-gray-50 rounded-xl">
          <div class="flex gap-3 mb-3">
            <input type="text" id="comment-author" placeholder="昵称（选填）" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
          </div>
          <textarea id="comment-content" rows="3" placeholder="写下你的评论..." class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none resize-none"></textarea>
          <div class="flex justify-end mt-2">
            <button onclick="submitComment()" class="px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">发布评论</button>
          </div>
        </div>
        
        <!-- Comments List -->
        <div id="comments-list" class="space-y-4">
          <p class="text-gray-400 text-center py-4">暂无评论，快来抢沙发吧！</p>
        </div>
      </div>
    </article>
    
    <!-- Sidebar -->
    <aside class="lg:w-72 flex-shrink-0">
      <Sidebar />
    </aside>
  </div>
</BaseLayout>

<script is:inline>
  var POST_SLUG = window.location.pathname.split('/').filter(Boolean).pop();
  var AVATAR_COLORS = ['bg-blue-500', 'bg-green-500', 'bg-purple-500', 'bg-pink-500', 'bg-indigo-500', 'bg-yellow-500', 'bg-red-500', 'bg-teal-500'];

  // 隐藏内容处理
  (function() {
    var body = document.getElementById('post-body');
    if (!body) return;
    var html = body.innerHTML;
    var hiddenMatch = html.match(/<!--hidden-->([\s\S]*?)<!--\/hidden-->/);
    if (hiddenMatch) {
      body.innerHTML = html.replace(/<!--hidden-->[\s\S]*?<!--\/hidden-->/, '');
      body.setAttribute('data-hidden-html', hiddenMatch[1].trim());
      var hiddenHtml = body.getAttribute('data-hidden-html');
      var wrapper = document.getElementById('hidden-content-wrapper');
      var hasCommented = false;
      try {
        var allCmts = JSON.parse(localStorage.getItem('blog_comments') || '{}');
        var postCmts = allCmts[POST_SLUG] || [];
        hasCommented = postCmts.length > 0;
      } catch(e) {}
      if (hasCommented) {
        wrapper.innerHTML = '<div class="mt-6 p-4 bg-amber-50 border-2 border-dashed border-amber-300 rounded-xl"><div class="flex items-center gap-2 mb-2"><svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg><span class="font-semibold text-amber-700">隐藏内容（评论后可见）</span></div><div class="prose prose-lg max-w-none">' + hiddenHtml + '</div></div>';
      } else {
        wrapper.innerHTML = '<div class="mt-6 p-4 bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl text-center"><svg class="w-8 h-8 text-gray-400 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg><p class="text-gray-500 text-sm">此处为隐藏内容，<a href="javascript:void(0)" onclick="document.getElementById(\'comment-content\').focus()" class="text-indigo-500 hover:text-indigo-700 underline">评论后即可查看</a></p></div>';
      }
    }
  })();

  function getComments() {
    var all = JSON.parse(localStorage.getItem('blog_comments') || '{}');
    return all[POST_SLUG] || [];
  }

  function saveComments(comments) {
    var all = JSON.parse(localStorage.getItem('blog_comments') || '{}');
    all[POST_SLUG] = comments;
    localStorage.setItem('blog_comments', JSON.stringify(all));
    // 同步到管理后台评论
    var adminComments = JSON.parse(localStorage.getItem('admin_comments') || '[]');
    adminComments = [];
    Object.keys(all).forEach(function(slug) {
      all[slug].forEach(function(c) {
        adminComments.push(Object.assign({}, c, { postSlug: slug }));
      });
    });
    localStorage.setItem('admin_comments', JSON.stringify(adminComments));
  }

  function renderComments() {
    var comments = getComments();
    var list = document.getElementById('comments-list');
    if (comments.length === 0) {
      list.innerHTML = '<p class="text-gray-400 text-center py-4">暂无评论，快来抢沙发吧！</p>';
      return;
    }
    list.innerHTML = comments.map(function(c, i) {
      var colorIndex = c.author ? c.author.charCodeAt(0) % AVATAR_COLORS.length : i % AVATAR_COLORS.length;
      var initial = c.author ? c.author.charAt(0).toUpperCase() : '匿';
      var repliesHtml = '';
      if (c.replies && c.replies.length > 0) {
        repliesHtml = '<div class="mt-3 ml-8 pl-4 border-l-2 border-blue-200 space-y-3">' +
          c.replies.map(function(r) {
            var rColorIndex = r.author ? r.author.charCodeAt(0) % AVATAR_COLORS.length : 0;
            var rInitial = r.author ? r.author.charAt(0).toUpperCase() : '匿';
            return '<div class="flex items-start gap-2">' +
              '<div class="w-6 h-6 rounded-full ' + AVATAR_COLORS[rColorIndex] + ' flex items-center justify-center text-white text-xs font-bold flex-shrink-0">' + rInitial + '</div>' +
              '<div><span class="text-sm font-medium text-gray-800">' + (r.author || '匿名') + '</span>' +
              '<span class="text-xs text-gray-400 ml-2">' + (r.createdAt || '') + '</span>' +
              '<p class="text-sm text-gray-600 mt-1">' + r.content + '</p></div></div>';
          }).join('') +
        '</div>';
      }
      return '<div class="p-4 bg-gray-50 rounded-xl">' +
        '<div class="flex items-start gap-3">' +
          '<div class="w-9 h-9 rounded-full ' + AVATAR_COLORS[colorIndex] + ' flex items-center justify-center text-white text-sm font-bold flex-shrink-0">' + initial + '</div>' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<span class="font-medium text-gray-900">' + (c.author || '匿名') + '</span>' +
              '<span class="text-xs text-gray-400">' + (c.createdAt ? c.createdAt.substring(0, 10) : '') + '</span>' +
            '</div>' +
            '<p class="text-gray-700 text-sm">' + c.content + '</p>' +
            '<button onclick="showReplyForm(' + i + ')" class="text-xs text-indigo-500 hover:text-indigo-700 mt-2 inline-flex items-center gap-1">' +
              '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path></svg>' +
              '回复' +
            '</button>' +
            '<div id="reply-form-' + i + '" class="hidden mt-3">' +
              '<div class="flex gap-2 mb-2">' +
                '<input type="text" id="reply-author-' + i + '" placeholder="昵称（选填）" class="flex-1 px-3 py-1.5 border border-gray-300 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 outline-none" />' +
              '</div>' +
              '<div class="flex gap-2">' +
                '<input type="text" id="reply-content-' + i + '" placeholder="写下你的回复..." class="flex-1 px-3 py-1.5 border border-gray-300 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 outline-none" />' +
                '<button onclick="submitReply(' + i + ')" class="px-3 py-1.5 bg-blue-500 text-white rounded-lg text-xs hover:bg-blue-600">回复</button>' +
              '</div>' +
            '</div>' +
            repliesHtml +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  function submitComment() {
    var author = document.getElementById('comment-author').value.trim() || '匿名';
    var content = document.getElementById('comment-content').value.trim();
    if (!content) { alert('请输入评论内容'); return; }
    var comments = getComments();
    comments.push({
      id: Date.now().toString(),
      author: author,
      content: content,
      createdAt: new Date().toISOString(),
      replies: []
    });
    saveComments(comments);
    renderComments();
    document.getElementById('comment-author').value = '';
    document.getElementById('comment-content').value = '';
    // 刷新隐藏内容
    var wrapper = document.getElementById('hidden-content-wrapper');
    var hiddenDiv = wrapper && wrapper.querySelector('.bg-gray-50');
    if (hiddenDiv) {
      var body = document.getElementById('post-body');
      var origHtml = body ? body.getAttribute('data-hidden-html') : '';
      if (origHtml) {
        wrapper.innerHTML = '<div class="mt-6 p-4 bg-amber-50 border-2 border-dashed border-amber-300 rounded-xl"><div class="flex items-center gap-2 mb-2"><svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg><span class="font-semibold text-amber-700">隐藏内容（评论后可见）</span></div><div class="prose prose-lg max-w-none">' + origHtml + '</div></div>';
      }
    }
  }

  function showReplyForm(index) {
    var form = document.getElementById('reply-form-' + index);
    if (form) form.classList.toggle('hidden');
  }

  function submitReply(index) {
    var author = document.getElementById('reply-author-' + index).value.trim() || '匿名';
    var content = document.getElementById('reply-content-' + index).value.trim();
    if (!content) { alert('请输入回复内容'); return; }
    var comments = getComments();
    if (!comments[index].replies) comments[index].replies = [];
    comments[index].replies.push({
      id: Date.now().toString(),
      author: author,
      content: content,
      createdAt: new Date().toISOString()
    });
    saveComments(comments);
    renderComments();
  }

  // 分享功能
  function shareToX() {
    var url = encodeURIComponent(window.location.href);
    var title = encodeURIComponent(document.title);
    window.open('https://twitter.com/intent/tweet?url=' + url + '&text=' + title, '_blank', 'width=600,height=400');
  }

  function shareToFacebook() {
    var url = encodeURIComponent(window.location.href);
    window.open('https://www.facebook.com/sharer/sharer.php?u=' + url, '_blank', 'width=600,height=400');
  }

  function shareToWeChat() {
    var url = window.location.href;
    // 微信分享：复制链接提示用户在微信中打开
    var modal = document.createElement('div');
    modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:9999;';
    modal.innerHTML = '<div style="background:white;border-radius:16px;padding:32px;text-align:center;max-width:360px;">' +
      '<div style="font-size:48px;margin-bottom:16px;">📱</div>' +
      '<h3 style="font-size:18px;font-weight:bold;margin-bottom:8px;">分享到微信</h3>' +
      '<p style="color:#666;font-size:14px;margin-bottom:16px;">请复制链接后在微信中粘贴分享</p>' +
      '<div style="background:#f3f4f6;border-radius:8px;padding:12px;margin-bottom:16px;word-break:break-all;font-size:13px;color:#333;">' + url + '</div>' +
      '<button onclick="navigator.clipboard.writeText(\'' + url + '\');this.textContent=\'已复制！\';setTimeout(function(){document.body.removeChild(document.querySelector(\'div[style*=fixed]\'))},1500)" style="background:#07c160;color:white;border:none;padding:10px 32px;border-radius:8px;font-size:14px;cursor:pointer;">复制链接</button>' +
      '<button onclick="document.body.removeChild(this.closest(\'div[style*=fixed]\'))" style="margin-left:8px;background:#e5e7eb;color:#333;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;">关闭</button>' +
    '</div>';
    document.body.appendChild(modal);
    modal.addEventListener('click', function(e) { if (e.target === modal) document.body.removeChild(modal); });
  }

  function shareToWeibo() {
    var url = encodeURIComponent(window.location.href);
    var title = encodeURIComponent(document.title);
    window.open('https://service.weibo.com/share/share.php?url=' + url + '&title=' + title, '_blank', 'width=600,height=400');
  }

  function copyLink() {
    var url = window.location.href;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(function() {
        var btn = document.getElementById('copy-btn');
        var original = btn.innerHTML;
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 已复制';
        setTimeout(function() { btn.innerHTML = original; }, 2000);
      });
    } else {
      var input = document.createElement('input');
      input.value = url;
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
      var btn = document.getElementById('copy-btn');
      var original = btn.innerHTML;
      btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 已复制';
      setTimeout(function() { btn.innerHTML = original; }, 2000);
    }
  }

  // 初始化渲染评论
  renderComments();

  // 阅读计数（IP去重）
  (function(){
    var VIEWS_KEY='xiaohe_post_views';
    var el=document.getElementById('post-views');
    if(!el)return;
    var slug=el.getAttribute('data-slug');
    var baseline=parseInt(el.getAttribute('data-baseline')||'0');
    var stored={};
    try{stored=JSON.parse(localStorage.getItem(VIEWS_KEY)||'{}')}catch(e){}
    var inc=parseInt(stored[slug]||'0');
    el.textContent=baseline+inc;

    fetch('https://api.ipify.org?format=json')
      .then(function(r){return r.json()})
      .then(function(data){
        var ip=data.ip||'';
        if(!ip)return;
        return crypto.subtle.digest('SHA-256',new TextEncoder().encode(ip+'_'+slug))
          .then(function(buf){
            var arr=Array.from(new Uint8Array(buf));
            var hash=arr.map(function(b){return b.toString(16).padStart(2,'0')}).join('').substring(0,16);
            var dedupKey='xiaohe_pv_'+hash;
            if(!localStorage.getItem(dedupKey)){
              localStorage.setItem(dedupKey,'1');
              inc+=1;
              stored[slug]=String(inc);
              localStorage.setItem(VIEWS_KEY,JSON.stringify(stored));
              el.textContent=baseline+inc;
            }
          });
      })
      .catch(function(){});
  })();
</script>
