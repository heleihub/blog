---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getCategories } from '../../lib/content';
import { getViews } from '../../lib/config';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryDefinitions = await getCategories();
const categoryNameMap = new Map<string, string>();
categoryDefinitions.forEach((cat: any) => {
  categoryNameMap.set(cat.slug || cat.id, cat.name);
});

const viewsData = await getViews();
---

<BaseLayout title="全部文章 - XiaoHe Blog">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">全部文章</h1>
    
    {sortedPosts.length === 0 ? (
      <p class="text-gray-500 text-center py-16">暂无文章</p>
    ) : (
      <div class="space-y-6">
        {sortedPosts.map(post => (
          <article class="bg-white rounded-xl shadow-sm p-6 hover:shadow-md transition-shadow">
            <div class="flex gap-6">
              {post.data.coverImage && (
                <a href={`/posts/${post.slug}`} class="flex-shrink-0">
                  <img 
                    src={post.data.coverImage} 
                    alt={post.data.title}
                    class="w-48 h-32 object-cover rounded-lg hover:opacity-90 transition-opacity"
                  />
                </a>
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <time datetime={post.data.date}>{post.data.date}</time>
                  <span>•</span>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  <span class="post-views" data-slug={post.slug} data-baseline={String(viewsData[post.slug] || 0)}>{viewsData[post.slug] || 0}</span> 阅读
                  <span>•</span>
                  <span>{post.data.author}</span>
                  {post.data.category && (
                    <>
                      <span>•</span>
                      <a href={`/categories/${post.data.category}`} class="text-indigo-600 hover:text-indigo-800">
                        {categoryNameMap.get(post.data.category) || post.data.category}
                      </a>
                    </>
                  )}
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-2 hover:text-indigo-600 transition-colors">
                  <a href={`/posts/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p class="text-gray-600 line-clamp-2">{post.data.excerpt}</p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {post.data.tags.map((tag: string) => (
                    <a 
                      href={`/tags/${tag}`}
                      class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full hover:bg-gray-200 transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script is:inline>
(function(){
  var VIEWS_KEY='xiaohe_post_views';
  var stored={};
  try{stored=JSON.parse(localStorage.getItem(VIEWS_KEY)||'{}')}catch(e){}
  document.querySelectorAll('.post-views').forEach(function(el){
    var slug=el.getAttribute('data-slug');
    var baseline=parseInt(el.getAttribute('data-baseline')||'0');
    var inc=parseInt(stored[slug]||'0');
    el.textContent=baseline+inc;
  });
})();
</script>
